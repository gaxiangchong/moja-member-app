# For local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/moja_member?schema=public"

# Alternative Prisma Postgres (cloud)
# DATABASE_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"
# DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
JWT_SECRET="generate-a-long-random-string"
JWT_EXPIRES_IN_SEC=604800
PHONE_DEFAULT_REGION="SG"
OTP_TTL_MINUTES=10
OTP_REQUEST_WINDOW_MINUTES=15
OTP_MAX_REQUESTS_PER_WINDOW=3

# OTP delivery mode:
# - auto: use WhatsApp if configured, otherwise dev/mock response
# - mock: always return OTP in API response (for testing)
# - whatsapp: require WhatsApp config, otherwise fail
OTP_DELIVERY_MODE=mock
# Optional fixed OTP code in mock mode (handy for demos/tests)
OTP_MOCK_FIXED_CODE=123456
ADMIN_API_KEYS="comma-separated-admin-keys"
# Admin UI JWT (Bearer). If unset, JWT_SECRET is used. typ=admin in payload.
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN_SEC=604800
# First-time setup: POST /admin/auth/bootstrap with email/password when admin_users is empty.
# Set to true only for trusted operators; phone changes are audited separately.
ADMIN_ALLOW_PHONE_CHANGE=false
# Comma-separated voucher codes that support may assign via POST /admin/customers/:id/vouchers/goodwill
# SUPPORT_GOODWILL_VOUCHER_CODES=GOODWILL5,COMP10
PORT=3153

# --- Xendit Payments API (v3 payment_requests) — wallet top-up & future flows
# @see https://docs.xendit.co/docs/how-payments-api-work
# XENDIT_SECRET_KEY=
# Webhook URL: POST {PUBLIC_API}/webhooks/xendit — set the same token in the Xendit dashboard
# XENDIT_WEBHOOK_TOKEN=
# XENDIT_COUNTRY=MY
# XENDIT_CURRENCY=MYR
# Channel list depends on country; examples: TOUCHNGO, SHOPEEPAY, GCASH (PH)
# CARDS requires extra backend/frontend implementation (card_details/tokenization), so keep it out for now.
# XENDIT_DEFAULT_CHANNEL_CODE=TOUCHNGO
# Comma-separated PAY channels for Shop checkout (member picks one; must match Xendit test dashboard).
# XENDIT_SHOP_CHANNEL_CODES=TOUCHNGO,SHOPEEPAY,FPX
# Card checkout in this app uses payment_token_id (tokenized flow), not raw PAN/card_details through backend.
# When true, shop checkout skips Xendit; use POST /payments/demo/complete-shop-order to finish test orders.
# PAYMENTS_DEMO_MODE=true
# Optional override for success/failure redirects (defaults to first CLIENT_WEB_ORIGIN)
# MEMBER_APP_PUBLIC_URL=http://localhost:5193
# Required for card tokenization via Xendit Components: HTTPS origins only (comma-separated)
# XENDIT_COMPONENTS_ORIGINS=https://your-https-member-web.example
# XENDIT_API_BASE=https://api.xendit.co
# XENDIT_API_VERSION=2024-11-11

# CORS: comma-separated origins for the member web app (5193) and ops queue display (5194)
CLIENT_WEB_ORIGIN=http://localhost:5193,http://localhost:5194

# Kitchen / operations queue API (header: x-ops-api-key). Used by ops-queue-web.
OPS_QUEUE_API_KEY=change-me-ops-queue-secret

# Feature flags (true/1/on/yes to enable)
FEATURE_SHOP_SSO=false
FEATURE_CAMPAIGN_ASYNC=false

# Shop SSO handoff (member API issues JWT; shop site verifies at /sso/consume)
# SHOP_WEB_BASE_URL: public shop site origin (used to build https://origin/sso/consume?handoff=...)
SHOP_WEB_BASE_URL=http://localhost:3000
# Issuer claim must match what the shop validates (often your member API public base URL)
SHOP_HANDOFF_ISSUER=http://localhost:3153
SHOP_HANDOFF_AUDIENCE=shop
# Optional; defaults to JWT_SECRET if unset
# SHOP_HANDOFF_JWT_SECRET=
SHOP_HANDOFF_TTL_SEC=45

# WhatsApp Cloud API (Meta) — required in production for OTP delivery
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_GRAPH_API_VERSION=v21.0
# Optional: approved auth template with one body parameter {{1}} = OTP code
# WHATSAPP_OTP_TEMPLATE_NAME=
# WHATSAPP_OTP_TEMPLATE_LANG=en

