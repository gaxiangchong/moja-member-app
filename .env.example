DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET="generate-a-long-random-string"
JWT_EXPIRES_IN_SEC=604800
PHONE_DEFAULT_REGION="SG"
OTP_TTL_MINUTES=10
OTP_REQUEST_WINDOW_MINUTES=15
OTP_MAX_REQUESTS_PER_WINDOW=3
ADMIN_API_KEYS="comma-separated-admin-keys"
PORT=3000

# CORS: comma-separated origins for the member web app (Vite default http://localhost:5173)
CLIENT_WEB_ORIGIN=http://localhost:5173

# WhatsApp Cloud API (Meta) — required in production for OTP delivery
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_GRAPH_API_VERSION=v21.0
# Optional: approved auth template with one body parameter {{1}} = OTP code
# WHATSAPP_OTP_TEMPLATE_NAME=
# WHATSAPP_OTP_TEMPLATE_LANG=en

# Prisma Postgres (optional): use pooled URL for app + direct for migrations
# DATABASE_URL="postgres://...@pooled.db.prisma.io:5432/postgres?sslmode=require"
# DIRECT_URL="postgres://...@db.prisma.io:5432/postgres?sslmode=require"
