# Public API base (member + ops queue run on another origin in production)
VITE_API_BASE_URL=http://localhost:3153

# IANA timezone for “today” filter (pickup Date: yyyy-mm-dd vs shop calendar day)
# VITE_SHOP_TIMEZONE=Asia/Kuala_Lumpur

# Optional dev convenience: same value as server OPS_QUEUE_API_KEY (Vite only exposes VITE_*)
# VITE_OPS_API_KEY=your-secret-here
