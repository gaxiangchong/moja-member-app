generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CustomerStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

enum VoucherStatus {
  ISSUED
  REDEEMED
  EXPIRED
  VOID
}

enum WalletTxnType {
  TOPUP
  SPEND
  REFUND
  MANUAL_ADJUSTMENT
  PROMOTIONAL_BONUS
  REVERSAL
}

enum MasterEntryCategory {
  MEMBER_TIER
  STORE
  SOURCE_CHANNEL
  NOTE_CATEGORY
  TAG_VOCAB
}

enum BusinessRuleKind {
  WALLET_BONUS
  LOYALTY_EARN
  LOYALTY_REDEEM
  LOYALTY_EXPIRY
}

enum ImportBatchKind {
  CUSTOMER_MASTER
  WALLET_ADJUSTMENT
  LOYALTY_ADJUSTMENT
  VOUCHER_ASSIGNMENT
  TAGS
}

enum ImportBatchStatus {
  PREVIEW
  COMMITTED
  FAILED
}

enum ExportJobStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ExportFormat {
  CSV
  XLSX
}

enum ExportJobKind {
  CUSTOMERS
  WALLET_LEDGER
  POINTS_LEDGER
  VOUCHERS_ISSUED
  VOUCHERS_REDEEMED
  AUDIT_LOGS
  IMPORT_BATCHES
  SEGMENT_AUDIENCE
}

enum AdminRoleCode {
  SUPER_ADMIN
  CRM_ADMIN
  MARKETING_ADMIN
  FINANCE_ADMIN
  SUPPORT_ADMIN
  READONLY_ANALYST
  STORE_MANAGER
}

enum ApprovalRequestKind {
  WALLET_REVERSAL
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// When to auto-issue a voucher (evaluation engine uses rules later).
enum VoucherPushTriggerType {
  NEWCOMER
  TOPUP_THRESHOLD
  REFERRAL
  BIRTHDAY
  REENGAGEMENT
}

model Customer {
  id          String         @id @default(uuid()) @db.Uuid
  phoneE164   String         @unique @map("phone_e164")
  status      CustomerStatus @default(DRAFT)
  displayName String?        @map("display_name")
  email       String?
  birthday    DateTime?      @db.Date
  gender      String?        @map("gender")
  preferredStore String?     @map("preferred_store")
  signupSource String        @default("otp") @map("signup_source")
  memberTier  String         @default("standard") @map("member_tier")
  marketingConsent Boolean   @default(false) @map("marketing_consent")
  notes       String?        @map("notes")
  tags        String[]       @default([]) @map("tags")
  lastLoginAt DateTime?      @map("last_login_at")
  /// Shareable code for referral attribution (set on first login / create).
  referralCode          String?   @unique @map("referral_code") @db.VarChar(20)
  referredByCustomerId  String?   @map("referred_by_customer_id") @db.Uuid
  referredBy            Customer? @relation("CustomerReferrer", fields: [referredByCustomerId], references: [id], onDelete: SetNull)
  referredMembers       Customer[] @relation("CustomerReferrer")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  wallet         LoyaltyWallet?
  storedWallet   StoredWallet?
  ledgerEntries  LoyaltyLedgerEntry[]
  storedWalletLedgerEntries StoredWalletLedgerEntry[]
  vouchers          CustomerVoucher[]
  otpChallenges     OtpChallenge[]
  shopHandoffJtis   ShopHandoffJti[]
  orders            CustomerOrder[]

  @@index([displayName])
  @@index([email])
  @@index([signupSource])
  @@index([memberTier])
  @@index([referredByCustomerId])
  @@map("customers")
}

model CustomerOrder {
  id                 String    @id @default(uuid()) @db.Uuid
  customerId         String    @map("customer_id") @db.Uuid
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  /// Public pickup / order number (sequential). Shown on receipts, ops queue, and member QR.
  orderNumber        Int       @unique @default(autoincrement()) @map("order_number")
  totalCents         Int       @map("total_cents")
  status             String    @default("placed") @db.VarChar(32)
  fulfillmentSummary Json?     @map("fulfillment_summary")
  placedAt           DateTime  @default(now()) @map("placed_at")
  completedAt        DateTime? @map("completed_at")

  lines CustomerOrderLine[]

  @@index([customerId, placedAt])
  @@index([status, placedAt])
  @@map("customer_orders")
}

/// UTC calendar date when back office closed books for that day (sales report).
model DailySalesClose {
  id           String   @id @default(uuid()) @db.Uuid
  businessDate DateTime @map("business_date") @db.Date
  closedAt     DateTime @default(now()) @map("closed_at")

  @@unique([businessDate])
  @@map("daily_sales_closes")
}

model CustomerOrderLine {
  id             String        @id @default(uuid()) @db.Uuid
  orderId        String        @map("order_id") @db.Uuid
  order          CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String        @map("product_id")
  name           String
  variantLabel   String?       @map("variant_label")
  unitPriceCents Int           @map("unit_price_cents")
  qty            Int
  imageUrl       String?       @map("image_url")

  @@index([orderId])
  @@index([productId])
  @@map("customer_order_lines")
}

model OtpChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  phoneE164  String    @map("phone_e164")
  otpHash    String    @map("otp_hash")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  customerId String?   @map("customer_id") @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([phoneE164, createdAt])
  @@map("otp_challenges")
}

model OtpRequestLog {
  id        String   @id @default(uuid()) @db.Uuid
  phoneE164 String   @map("phone_e164")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phoneE164, createdAt])
  @@map("otp_request_logs")
}

model LoyaltyWallet {
  id           String   @id @default(uuid()) @db.Uuid
  customerId   String   @unique @map("customer_id") @db.Uuid
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pointsCached Int      @default(0) @map("points_cached")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("loyalty_wallets")
}

model LoyaltyLedgerEntry {
  id             String   @id @default(uuid()) @db.Uuid
  customerId     String   @map("customer_id") @db.Uuid
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deltaPoints    Int      @map("delta_points")
  balanceAfter   Int      @map("balance_after")
  referenceType  String?  @map("reference_type")
  referenceId    String?  @map("reference_id") @db.Uuid
  reason         String
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([customerId, createdAt])
  @@index([referenceType, referenceId])
  @@map("loyalty_ledger_entries")
}

model StoredWallet {
  id                     String   @id @default(uuid()) @db.Uuid
  customerId             String   @unique @map("customer_id") @db.Uuid
  customer               Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  balanceCents           Int      @default(0) @map("balance_cents")
  lifetimeTopUpCents     Int      @default(0) @map("lifetime_top_up_cents")
  lifetimeSpentCents     Int      @default(0) @map("lifetime_spent_cents")
  manualAdjustmentCents  Int      @default(0) @map("manual_adjustment_cents")
  promotionalCreditCents Int      @default(0) @map("promotional_credit_cents")
  pendingCreditCents     Int      @default(0) @map("pending_credit_cents")
  isFrozen               Boolean  @default(false) @map("is_frozen")
  updatedAt              DateTime @updatedAt @map("updated_at")

  entries StoredWalletLedgerEntry[]

  @@map("stored_wallets")
}

model StoredWalletLedgerEntry {
  id              String      @id @default(uuid()) @db.Uuid
  walletId         String      @map("wallet_id") @db.Uuid
  wallet           StoredWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  customerId       String      @map("customer_id") @db.Uuid
  customer         Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type             WalletTxnType
  amountCents      Int         @map("amount_cents")
  balanceBefore    Int         @map("balance_before")
  balanceAfter     Int         @map("balance_after")
  reason           String
  createdByType    String      @map("created_by_type")
  createdBy        String?     @map("created_by")
  reversedByTxnId  String?     @map("reversed_by_txn_id") @db.Uuid
  metadata         Json?
  createdAt        DateTime    @default(now()) @map("created_at")

  @@index([customerId, createdAt])
  @@index([walletId, createdAt])
  @@index([type, createdAt])
  @@index([reversedByTxnId])
  @@map("stored_wallet_ledger_entries")
}

model VoucherDefinition {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  title       String
  description String?
  pointsCost  Int?     @map("points_cost")
  isActive    Boolean  @default(true) @map("is_active")
  /// Image URL for member app rewards catalog (HTTPS recommended).
  imageUrl              String?   @map("image_url")
  /// Optional grouping in UI: food, drinks, other.
  rewardCategory        String?   @map("reward_category")
  /// Show in member app “Rewards” redeemable catalog.
  showInRewardsCatalog  Boolean   @default(true) @map("show_in_rewards_catalog")
  /// Catalog ordering (lower first).
  rewardSortOrder       Int       @default(0) @map("reward_sort_order")
  /// Redeemable / visible window in catalog (optional).
  rewardValidFrom       DateTime? @map("reward_valid_from")
  rewardValidUntil      DateTime? @map("reward_valid_until")
  /// Optional cap on total issued vouchers from this definition (null = unlimited).
  maxTotalIssued        Int?      @map("max_total_issued")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  instances    CustomerVoucher[]
  pushRules    VoucherPushRule[]

  @@map("voucher_definitions")
}

model VoucherPushRule {
  id                   String                 @id @default(uuid()) @db.Uuid
  name                 String
  description          String?
  isActive             Boolean                @default(true) @map("is_active")
  sortOrder            Int                    @default(0) @map("sort_order")
  triggerType          VoucherPushTriggerType @map("trigger_type")
  // JSON: withinDaysOfSignup, minLifetimeTopUpCents, minReferrals, inactiveDays, etc.
  triggerConfig        Json                   @map("trigger_config")
  voucherDefinitionId  String                 @map("voucher_definition_id") @db.Uuid
  voucherDefinition    VoucherDefinition      @relation(fields: [voucherDefinitionId], references: [id], onDelete: Restrict)
  maxGrantsPerCustomer Int?                   @map("max_grants_per_customer")
  cooldownDays         Int?                   @map("cooldown_days")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@index([voucherDefinitionId])
  @@map("voucher_push_rules")
}

model CustomerVoucher {
  id           String            @id @default(uuid()) @db.Uuid
  customerId   String            @map("customer_id") @db.Uuid
  customer     Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  definitionId String            @map("definition_id") @db.Uuid
  definition   VoucherDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  status       VoucherStatus     @default(ISSUED)
  issuedAt     DateTime          @default(now()) @map("issued_at")
  redeemedAt   DateTime?         @map("redeemed_at")
  expiresAt    DateTime?         @map("expires_at")
  referenceType String?          @map("reference_type")
  referenceId   String?         @map("reference_id") @db.Uuid
  campaignRunId String?          @map("campaign_run_id") @db.Uuid
  campaignRun   CampaignRun?     @relation(fields: [campaignRunId], references: [id], onDelete: SetNull)
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([customerId, status])
  @@index([updatedAt])
  @@unique([customerId, definitionId, campaignRunId])
  @@map("customer_vouchers")
}

model AuditLog {
  id           String    @id @default(uuid()) @db.Uuid
  actorType    String    @map("actor_type")
  actorId      String?   @map("actor_id")
  action       String
  entityType   String    @map("entity_type")
  entityId     String?   @map("entity_id") @db.Uuid
  metadata     Json?
  adminUserId  String?   @map("admin_user_id") @db.Uuid
  adminUser    AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  adminRole    String?   @map("admin_role")
  ipAddress    String?   @map("ip_address")
  reason       String?
  beforeValue  Json?     @map("before_value")
  afterValue   Json?     @map("after_value")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model AdminUser {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  passwordHash String       @map("password_hash")
  displayName  String?      @map("display_name")
  role         AdminRoleCode @map("role")
  isActive     Boolean      @default(true) @map("is_active")
  lastLoginAt  DateTime?    @map("last_login_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  auditLogs         AuditLog[]
  approvalsRequested ApprovalRequest[] @relation("ApprovalRequester")
  approvalsReviewed  ApprovalRequest[] @relation("ApprovalReviewer")

  @@map("admin_users")
}

model ApprovalRequest {
  id          String                @id @default(uuid()) @db.Uuid
  kind        ApprovalRequestKind
  status      ApprovalRequestStatus @default(PENDING)
  payload     Json
  requesterId String                @map("requester_id") @db.Uuid
  requester   AdminUser             @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  reviewerId  String?               @map("reviewer_id") @db.Uuid
  reviewer    AdminUser?            @relation("ApprovalReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewNote  String?               @map("review_note")
  createdAt   DateTime              @default(now()) @map("created_at")
  reviewedAt  DateTime?             @map("reviewed_at")

  @@index([status, createdAt])
  @@index([requesterId])
  @@map("approval_requests")
}

model SegmentAudience {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  filters     Json     @map("filters")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  campaignRuns CampaignRun[]

  @@map("segment_audiences")
}

model CampaignRun {
  id                 String             @id @default(uuid()) @db.Uuid
  segmentAudienceId  String?            @map("segment_audience_id") @db.Uuid
  segmentAudience    SegmentAudience?   @relation(fields: [segmentAudienceId], references: [id], onDelete: SetNull)
  filtersSnapshot    Json?              @map("filters_snapshot")
  action             String
  payload            Json
  createdBy          String             @map("created_by")
  createdAt          DateTime           @default(now()) @map("created_at")
  customerMatched    Int                @default(0) @map("customer_matched")
  customerSucceeded  Int                @default(0) @map("customer_succeeded")
  customerFailed     Int                @default(0) @map("customer_failed")
  customerProcessed  Int                @default(0) @map("customer_processed")
  errors             Json?
  status             CampaignRunStatus  @default(COMPLETED) @map("status")
  startedAt          DateTime?          @map("started_at")
  finishedAt         DateTime?          @map("finished_at")
  duplicatesSkipped  Int                 @default(0) @map("duplicates_skipped")

  voucherIssues CustomerVoucher[]

  @@index([createdAt])
  @@map("campaign_runs")
}

model ShopHandoffJti {
  jti        String   @id
  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("shop_handoff_jtis")
}

model ImportBatch {
  id           String            @id @default(uuid()) @db.Uuid
  kind         ImportBatchKind
  fileName     String            @map("file_name")
  fileStoragePath String?        @map("file_storage_path")
  uploadedBy   String            @map("uploaded_by")
  uploadedAt   DateTime          @default(now()) @map("uploaded_at")
  status       ImportBatchStatus @default(PREVIEW)
  totalRows    Int               @default(0) @map("total_rows")
  successRows  Int               @default(0) @map("success_rows")
  failedRows   Int               @default(0) @map("failed_rows")
  previewRows  Json?             @map("preview_rows")
  rowErrors    Json?             @map("row_errors")
  summary      Json?

  @@index([kind, uploadedAt])
  @@map("import_batches")
}

model ExportJob {
  id           String          @id @default(uuid()) @db.Uuid
  kind         ExportJobKind
  format       ExportFormat
  status       ExportJobStatus @default(PENDING)
  params       Json?
  rowCount     Int?            @map("row_count")
  fileName     String?         @map("file_name")
  storagePath  String?         @map("storage_path")
  errorMessage String?         @map("error_message")
  createdBy    String          @map("created_by")
  createdAt    DateTime        @default(now()) @map("created_at")
  completedAt  DateTime?       @map("completed_at")

  @@index([createdAt])
  @@map("export_jobs")
}

model MasterEntry {
  id        String              @id @default(uuid()) @db.Uuid
  category  MasterEntryCategory
  code      String
  label     String
  sortOrder Int                 @default(0) @map("sort_order")
  isActive  Boolean             @default(true) @map("is_active")
  metadata  Json?
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@unique([category, code])
  @@index([category, isActive])
  @@map("master_entries")
}

model BusinessRule {
  id        String           @id @default(uuid()) @db.Uuid
  kind      BusinessRuleKind
  name      String
  config    Json
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([kind, isActive])
  @@map("business_rules")
}

enum WorkCalendarDayType {
  REGULAR
  OFF
  PUBLIC_HOLIDAY
}

model PayrollSettings {
  id                           String   @id @default("default")
  standardWorkdayMinutes         Int      @default(480) @map("standard_workday_minutes")
  overtimeMultiplierBps        Int      @default(15000) @map("overtime_multiplier_bps")
  publicHolidayMultiplierBps   Int      @default(20000) @map("public_holiday_multiplier_bps")
  offDayWorkedMultiplierBps    Int      @default(10000) @map("off_day_worked_multiplier_bps")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@map("payroll_settings")
}

model Employee {
  id                 String               @id @default(uuid()) @db.Uuid
  employeeCode       String               @unique @map("employee_code")
  displayName        String               @map("display_name")
  positionTitle      String               @default("") @map("position_title")
  hourlyRateCents    Int                  @default(0) @map("hourly_rate_cents")
  commissionRateBps  Int                  @default(0) @map("commission_rate_bps")
  isActive           Boolean              @default(true) @map("is_active")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  timeEntries        EmployeeTimeEntry[]

  @@map("employees")
}

model EmployeeTimeEntry {
  id          String    @id @default(uuid()) @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockInAt   DateTime  @map("clock_in_at")
  clockOutAt  DateTime? @map("clock_out_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([employeeId, clockInAt])
  @@map("employee_time_entries")
}

model WorkCalendarDay {
  id      String               @id @default(uuid()) @db.Uuid
  date    DateTime             @unique @db.Date
  dayType WorkCalendarDayType  @map("day_type")
  label   String?

  @@map("work_calendar_days")
}
